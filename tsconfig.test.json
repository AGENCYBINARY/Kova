  "compilerOptions": {
    "noEmit": false,
    "outDir": ".test-dist",
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "incremental": false,
    "plugins": []
  },
  "include": [
    "tests/**/*.ts",
    "src/lib/actions/batch-execution.ts",
    "src/lib/agent/execution-governance.ts",
    "src/lib/assistant/profile.ts",
    "src/lib/dashboard-data.ts",
    "src/lib/dashboard/query.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
